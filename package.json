{
  "scripts": {
    "dev": "concurrently -k -n api,web \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "PORT=5175 tsx watch --env-file .env src/server/index.ts",
    "dev:web": "vite",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile --typescript",
    "bddgen": "bddgen",
    "test:e2e": "npm run build && npm run bddgen && node --env-file .env node_modules/.bin/playwright test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src",
    "build": "vite build"
  },
